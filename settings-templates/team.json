{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-5",
  "effortLevel": "normal",
  "theme": "system",
  "cleanupPeriodDays": 14,
  "enabledPlugins": [
    "code-review"
  ],
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git stash *)",
      "Bash(ls *)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Read(./*)",
      "Write(./src/*)",
      "Write(./tests/*)",
      "Write(./docs/*)",
      "Edit(./src/*)",
      "Edit(./tests/*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(rm -rf *)",
      "Bash(docker *)",
      "Write(./package.json)",
      "Write(./.github/*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.npmrc)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./.env.local)",
      "Bash(sudo *)",
      "Bash(npm publish *)",
      "Bash(git push --force *)"
    ]
  },
  "env": {
    "NODE_ENV": "development",
    "CI": "false"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[team-audit] Tool: Bash | $(date -u +%Y-%m-%dT%H:%M:%SZ)\" >> ~/.claude/audit.log"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "enabled": true
  },
  "sandbox": {
    "enabled": false
  }
}
